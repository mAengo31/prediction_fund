# Staging environment example. Copy values into the deployment platform, not into git.
# Do not commit real tokens, database URLs, venue credentials, private keys, or wallet data.

APP_ENV=staging
REQUIRE_API_TOKEN=true
ENABLE_OPENAPI_DOCS=false
DATABASE_URL=postgresql+psycopg://<user>:<password>@<host>:5432/<database>
PREDICTION_DESK_API_TOKEN=<set-in-platform-secret-store>
LOG_LEVEL=INFO

# Optional release metadata.
APP_VERSION=<git-sha-or-release-tag>
GIT_COMMIT=<git-sha>

# Public-read pilot guard. Keep unset unless an operator explicitly approves one tiny
# manual public-read collection run after fixture smoke and backup checks pass.
# CONFIRM_PUBLIC_READ_ONLY=true
# PUBLIC_READ_VENUES=kalshi
# MAX_PAYLOADS=5
