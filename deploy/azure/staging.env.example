# Azure staging environment checklist. Do not commit real values.

AZURE_RESOURCE_GROUP=prediction-desk-staging-cus-rg
AZURE_LOCATION=centralus
AZURE_CONTAINER_REGISTRY=predictiondesk3bbbab44cusacr
AZURE_CONTAINER_APP_NAME=prediction-desk-staging-api
AZURE_CONTAINER_APP_ENVIRONMENT=prediction-desk-staging-cae
AZURE_POSTGRES_SERVER_NAME=prediction-desk-staging-pg-cus-3bbbab
AZURE_POSTGRES_DATABASE=prediction_desk
AZURE_POSTGRES_ADMIN_USER=predictiondeskadmin
AZURE_POSTGRES_ADMIN_PASSWORD=<set-in-shell-or-secret-store>

IMAGE_NAME=prediction-desk
IMAGE_TAG=<git-sha-or-release-tag>

APP_ENV=staging
REQUIRE_API_TOKEN=true
ENABLE_OPENAPI_DOCS=false
PREDICTION_DESK_API_TOKEN=<set-in-shell-or-secret-store>
LOG_LEVEL=INFO
APP_VERSION=<git-sha-or-release-tag>
GIT_COMMIT=<git-sha>

# Used by scripts after deployment/migration.
API_BASE_URL=https://<container-app-fqdn>
DATABASE_URL=postgresql+psycopg://<user>:<url-encoded-password>@<server>.postgres.database.azure.com:5432/prediction_desk?sslmode=require

# Required gates. Keep unset unless intentionally performing these actions.
# CONFIRM_AZURE_STAGING_DEPLOY=true
# CONFIRM_PUBLIC_READ_ONLY=true
# MAX_PAYLOADS=5
# PUBLIC_READ_VENUES=kalshi
